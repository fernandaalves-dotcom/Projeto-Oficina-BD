---- Criando entidade de clientes----


CREATE TABLE Cliente(
  IdCliente INT AUTO_INCREMENT PRIMARY KEY,
  Nome VARCHAR(50) NOT NULL,
  CPF CHAR(11) NOT NULL UNIQUE,
  Email VARCHAR(100) NOT NULL,
  Telefone VARCHAR(50) NOT NULL,
  Data_Cadastro DATE NOT NULL, 
  Endereço VARCHAR(100) NOT NULL
  );


----- Criando entidade de veiculos---

 CREATE TABLE Veiculo(
  IdVeiculo INT AUTO_INCREMENT PRIMARY KEY,
  Modelo VARCHAR(50) NOT NULL,
  Ano_fabricação YEAR NOT NULL,
  Cor VARCHAR(10) NOT NULL,
  Placa CHAR(7) UNIQUE NOT NULL,
  Marca VARCHAR(50) NOT NULL,
  Id_cliente INT NOT NULL, 
  FOREIGN KEY (Id_cliente) 
   REFERENCES Cliente(IdCliente)
   );
  

----- Criando entidade de funcionarios----

CREATE TABLE Funcionario( 
  Idfuncionario INT AUTO_INCREMENT PRIMARY KEY,
  Nome VARCHAR(40)NOT NULL,
  Funçao VARCHAR(50) NOT NULL,
  Email VARCHAR(100) NOT NULL,
  Data_admissao DATE NOT NULL,
  Ativo BOOLEAN NOT NULL DEFAULT TRUE, 
   Id_Veiculo INT NOT NULL, 
  FOREIGN KEY (Id_Veiculo) 
   REFERENCES Veiculo(IdVeiculo)
  );

   
----  Criando entidade serviço---

   
CREATE TABLE Serviço(
  Idserviço INT AUTO_INCREMENT PRIMARY KEY,
  Descrição VARCHAR(100) NOT NULL,
  Preço DECIMAL (10,4) NOT NULL,
  Tempo_serviço TIME NOT NULL,
  Id_funcionario INT NOT NULL, 
  FOREIGN KEY (Id_funcionario) 
   REFERENCES Funcionario(Idfuncionario)
  );


